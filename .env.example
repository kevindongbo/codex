# 复制为 .env 后再修改。不要把真实 .env 提交到 Git。
COMPOSE_PROJECT_NAME=dongbo-erp

# 本机测试用 :80；生产环境改为 erp.example.com，Caddy 会自动申请 HTTPS 证书。
APP_SITE_ADDRESS=:80
HTTP_PORT=80
HTTPS_PORT=443

# Django：请使用密码管理器生成至少 50 位随机值。
DJANGO_SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
# 完整 JSON 迁移的服务端请求体上限；前端会在 20 MB 时提前拦截。
DJANGO_DATA_UPLOAD_MAX_MEMORY_SIZE=26214400

# 马来西亚 TikTok Shop 公开商品监控。至少配置 TikHub；Apify 是自动备用通道。
# 密钥只写入服务器 .env，绝不能提交到 Git。
TIKTOK_MONITOR_DEFAULT_MARKET=MY
TIKTOK_MONITOR_INTERVAL_MINUTES=60
TIKTOK_MONITOR_TIMEOUT_SECONDS=30
TIKHUB_API_TOKEN=
TIKHUB_BASE_URL=https://api.tikhub.io
TIKHUB_RETRIES=3
APIFY_API_TOKEN=
APIFY_BASE_URL=https://api.apify.com
APIFY_TIKTOK_ACTOR_ID=bovi/tiktok-shop-scraper
APIFY_TIKTOK_TIMEOUT_SECONDS=180
# 网页同步请求给备用通道的时间预算；定时任务仍使用上面的 180 秒。
TIKTOK_MONITOR_WEB_APIFY_TIMEOUT_SECONDS=15
# Apify 单个同步采集任务的最高允许费用，避免异常账单。
APIFY_TIKTOK_MAX_CHARGE_USD=0.25

# 内部系统：全员使用同一个隐藏组织。主账号可通过邮箱验证码登录、修改或找回密码。
INTERNAL_ORGANIZATION_NAME=东铂跨境
INTERNAL_ORGANIZATION_SLUG=dongbo-internal
OWNER_EMAIL_VERIFICATION_REQUIRED=false
OWNER_EMAIL_CODE_TTL_SECONDS=600
# 启用主账号邮箱验证前，请填写实际 SMTP 参数并将上一项设为 true。
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=

# PostgreSQL 密码请只用 URL 安全字符，DATABASE_URL 中必须与其保持一致。
POSTGRES_DB=dongbo_erp
POSTGRES_USER=dongbo_erp
POSTGRES_PASSWORD=REPLACE_WITH_URL_SAFE_RANDOM_PASSWORD
DATABASE_URL=postgresql://dongbo_erp:REPLACE_WITH_URL_SAFE_RANDOM_PASSWORD@db:5432/dongbo_erp
